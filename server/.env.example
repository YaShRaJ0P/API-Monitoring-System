############################################
# 🌐 Server Configuration
############################################
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

############################################
# 🌍 Client / CORS
############################################
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

############################################
# 🗄️ Database Configuration
############################################

# MongoDB (Atlas or local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>

# PostgreSQL
POSTGRES_URI=postgresql://<username>:<password>@localhost:5432/<database>

# Redis
REDIS_URI=redis://localhost:6379

# RabbitMQ
RABBITMQ_URI=amqp://localhost:5672

############################################
# 🔐 Authentication - Google OAuth
############################################
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

############################################
# 🔑 JWT Configuration
############################################
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

############################################
# AES-256-GCM Master Key - used to encrypt api_secrets at rest in the database.
# Generate with: openssl rand -hex 32
# CRITICAL: Never change this after first use or all stored secrets become unreadable.
############################################
ENCRYPTION_KEY=your_64_char_hex_master_key_here

# Token Expiry
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

############################################
# 🧠 Session Configuration
############################################
SESSION_SECRET=your_session_secret

############################################
# 📧 Email / SMTP Configuration
############################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

SMTP_FROM_NAME="Your App Name"
SMTP_FROM_ADDRESS=your_email@gmail.com

############################################
# ➡️ API
############################################
RATE_LIMIT_CAPACITY=500
RATE_LIMIT_REFILL_RATE=50